# SSH Monitor Configuration
# Copy this file to /opt/ssh-monitor/config.env and update the values

# Function Compute HTTP endpoint URL
FC_ENDPOINT=https://your-account-id.ap-northeast-1.fc.aliyuncs.com/2016-08-15/proxy/ecs-auto-stop/ssh-status-receiver/

# ECS Instance ID to monitor
INSTANCE_ID=i-xxxxx

# Authentication token (must match the token configured in Function Compute)
AUTH_TOKEN=your-secret-token-here
